                "exec": [
                  "pm.test('Status is 200 OK', function () { pm.response.to.have.status(200); });",
                  "pm.test('Response is JSON', function () { pm.response.to.be.json; });",
                  "var data = pm.response.json();",
                  "if (data.accessToken) { pm.environment.set('accessToken', data.accessToken); pm.collectionVariables.set('accessToken', data.accessToken); }",
                  "if (data.refreshToken) { pm.environment.set('refreshToken', data.refreshToken); pm.collectionVariables.set('refreshToken', data.refreshToken); }",
                  "pm.test('Login response has tokens', function () {",
                  "  pm.expect(data.accessToken).to.exist;",
                  "  pm.expect(data.refreshToken).to.exist;",
                  "});",
                  "pm.test('Access token saved', function () { pm.expect(pm.environment.get('accessToken')).to.be.ok; });",
                  "pm.test('Refresh token saved', function () { pm.expect(pm.environment.get('refreshToken')).to.be.ok; });"
                ]
              }
            }
