              "mode": "raw",
              "raw": "{\n  \"nickname\": \"minduser\",\n  \"email\": \"user@example.com\",\n  \"password\": \"Abcd1234!\",\n  \"personalInfoConsentAgreed\": true,\n  \"serviceTermsAgreed\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/signup",
