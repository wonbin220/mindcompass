  "paths": {
    "/auth/signup": {
      "post": {
        "tags": [
          "구현 API",
          "Implemented",
          "Authentication"
        ],
        "summary": "Sign up",
        "description": "Create a new user account.",
        "operationId": "post_auth_signup",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "example": {
                  "userId": 1,
                  "email": "user@example.com",
                  "nickname": "minduser",
                  "createdAt": "2026-03-30T10:00:00"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "email": "user@example.com",
                "password": "Abcd1234!",
                "nickname": "minduser"
              }
            }
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": [
          "구현 API",
          "Implemented",
          "Authentication"
        ],
        "summary": "Login",
        "description": "Authenticate a user and issue access and refresh tokens.",
        "operationId": "post_auth_login",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": {
                  "accessToken": "jwt-access-token",
                  "refreshToken": "jwt-refresh-token",
                  "user": {
                    "userId": 1,
                    "nickname": "minduser"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "email": "user@example.com",
                "password": "Abcd1234!"
              }
            }
          }
        }
      }
    },
    "/auth/refresh": {
      "post": {
        "tags": [
          "구현 API",
          "Implemented",
          "Authentication"
        ],
        "summary": "Refresh token",
        "description": "Refresh the access token using a refresh token.",
        "operationId": "post_auth_refresh",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": {
                  "accessToken": "new-access-token",
